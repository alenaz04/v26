<Page x:Class="finish.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:finish.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" MinHeight="600" MinWidth="500"
      Title="Авторизация">

    <Grid Background="White">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" >

            <TextBlock Text="Логин:"/>
            <TextBox x:Name="TxbLog"/>

            <TextBlock Text="Пароль:"/>
            <TextBox x:Name="TxbPas"/>

            <TextBlock Text="Соберите пазл (1, 2, 3, 4)"/>

            <UniformGrid Rows="2" Columns="2" Width="200" Height="200" x:Name="CaptchaGrid"/>

            <Button x:Name="btnLogin" Content="Войти" Click="Button_Click" Height="30" IsEnabled="False"/>

        </StackPanel>
    </Grid>
</Page>
